{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 3187",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "test": "vitest",
    "test:simple": "ts-node src/index.spec.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply aibaas --local",
    "db:seed": "tsx src/db/seeds/seed-test-bank.ts",
    "db:seed-models": "tsx src/db/seeds/seed-llm-models.ts",
    "benchmark": "tsx src/scripts/run-benchmark.ts",
    "benchmark:example": "tsx src/scripts/run-benchmark.ts --model=claude-3-5-sonnet-20241022 --difficulty=easy --limit=5 --verbose"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@tsndr/cloudflare-worker-jwt": "^3.2.0",
    "@types/handlebars": "^4.1.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "express-validator": "^7.3.0",
    "handlebars": "^4.7.8",
    "hono": "^4.12.26",
    "isomorphic-dompurify": "^2.31.0",
    "nanoid": "^5.1.14",
    "resend": "^6.14.0",
    "slugify": "^1.6.6",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.7",
    "tsx": "^4.20.6",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  },
  "overrides": {
    "svix": "1.92.2",
    "uuid": "^14.0.0",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    }
  }
}
